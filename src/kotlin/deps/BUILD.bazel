load("@rules_java//java:java_binary.bzl", "java_binary")
load("@rules_java//java:java_library.bzl", "java_library")

java_library(
    name = "nothing",
    srcs = ["Nothing.java"],
)

java_library(
    name = "runtime",
    srcs = ["Runtime.java"],
)

java_library(
    name = "multiply",
    srcs = ["Multiply.java"],
    deps = [":nothing"],
)

java_library(
    name = "square",
    srcs = ["Square.java"],
    deps = [":multiply"],
    runtime_deps = [":runtime"],
)

java_binary(
    name = "perform",
    srcs = ["Perform.java"],
    deps = [":square"],
    runtime_deps = [":runtime"],
    main_class = "deps.Perform",
)
